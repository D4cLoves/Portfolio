{
    "name": "vladislav-trubnikov/portfolio-backend",
    "description": "Symfony backend for developer portfolio contact form",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.1",
        "symfony/mailer": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/twig-bundle": "^7.1",
        "symfony/yaml": "^7.1",
        "symfony/dotenv": "^7.1",
        "nelmio/cors-bundle": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
